# --- DATABASE OPTIMIZATION SETTINGS ---
# These settings are now configured in config/database.php
# Uncomment and adjust as needed for your environment

# Persistent Connections - Reuse database connections (reduces new connections)
# Set to true for production to reduce connection overhead
# Set to false for development to avoid connection issues

DB_PERSISTENT=true

# Connection Timeout - How long to wait for database connection (seconds)
# Lower values fail faster if database is unavailable

DB_TIMEOUT=5

# Sticky Connections - Use same connection for read/write operations
# Helps maintain consistency and reduces connection switching

DB_STICKY=true

# For production with connection limits, consider:
# DB_PERSISTENT=true  # Enable persistent connections
# DB_TIMEOUT=3        # Fail fast if connection issues

SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

